# ── Generated by: npm run setup ──────────────────────────────────────────────
# Copy to web/.env (setup script does this automatically)

# MPCP SBA signing key — agent uses this to sign payment authorizations
# (EC P-256 PKCS8 PEM, \n escaped)
MPCP_SBA_SIGNING_PRIVATE_KEY_PEM=

# MPCP SBA public key — merchants use this to verify payment authorizations
MPCP_SBA_SIGNING_PUBLIC_KEY_PEM=

# XRPL Gateway wallet — holds XRP, signs payments on behalf of the robotaxi
# The robotaxi itself never holds this key (safe architecture)
XRPL_GATEWAY_SEED=
XRPL_GATEWAY_ADDRESS=

# XRPL Merchant wallets — receive XRP payments
XRPL_MERCHANT_TOLL_ADDRESS=
XRPL_MERCHANT_TOLL_SEED=
XRPL_MERCHANT_CHARGING_ADDRESS=
XRPL_MERCHANT_CHARGING_SEED=
XRPL_MERCHANT_PARKING_ADDRESS=
XRPL_MERCHANT_PARKING_SEED=

# Policy Authority
POLICY_AUTHORITY_URL=http://localhost:3000
PA_ADMIN_KEY=

# Demo config
ROBOTAXI_ID=TX-001
AGENT_URL=http://localhost:3001
