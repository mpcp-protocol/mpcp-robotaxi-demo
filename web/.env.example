# ── Web app environment (generated by npm run setup) ─────────────────────────

# Trust Gateway — required for online actions (session + proxy)
MPCP_GATEWAY_URL=http://localhost:8080
MPCP_GATEWAY_API_KEY=

# Base URL of this Next app (gateway must reach /api/merchant-x402/*)
AGENT_URL=http://localhost:3001

# MPCP SBA signing — offline demo only (local SBA + Trust Bundle)
MPCP_SBA_SIGNING_PRIVATE_KEY_PEM=
MPCP_SBA_SIGNING_PUBLIC_KEY_PEM=

# XRPL Gateway wallet (holds XRP, used by signer service)
XRPL_GATEWAY_SEED=
XRPL_GATEWAY_ADDRESS=

# XRPL Merchant addresses (receive payments)
XRPL_MERCHANT_TOLL_ADDRESS=
XRPL_MERCHANT_CHARGING_ADDRESS=
XRPL_MERCHANT_PARKING_ADDRESS=

# Policy Authority
POLICY_AUTHORITY_URL=http://localhost:3000
PA_ADMIN_KEY=

# Demo config
ROBOTAXI_ID=TX-001
